<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:paddingBottom="32dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="8dp">

        <!-- 大圆形开关 + 同心圆环 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingVertical="32dp">

            <ImageView
                android:id="@+id/concentricRings"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center"
                android:src="@drawable/concentric_rings"
                android:contentDescription="@null"
                android:visibility="gone" />

            <FrameLayout
                android:id="@+id/serviceToggle"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="center"
                android:background="@drawable/toggle_bg_off"
                android:clickable="true"
                android:elevation="8dp"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/serviceToggleIcon"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:src="@drawable/ic_power"
                        android:contentDescription="@string/service_title" />

                    <TextView
                        android:id="@+id/serviceToggleText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="已暂停"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </FrameLayout>

        </FrameLayout>

        <TextView
            android:id="@+id/toggleSubText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="-16dp"
            android:layout_marginBottom="24dp"
            android:text="点击开启打卡服务"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="@color/gray_text" />

        <!-- 极简统计行 -->
        <TextView
            android:id="@+id/statsSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:text="今日 0 次 · 最近 --:--"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="@color/gray_text" />

        <!-- 空态 -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="48dp"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="暂无触发记录"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                android:textColor="@color/gray_text" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="收到含关键字的短信或通知后自动记录"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="@color/gray_text_light" />
        </LinearLayout>

        <!-- 触发日志卡片列表 -->
        <LinearLayout
            android:id="@+id/logContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
