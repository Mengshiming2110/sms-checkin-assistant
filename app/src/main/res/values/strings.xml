    <!-- 使用说明 -->
    <string name="guide_title">使用说明</string>
    <string name="guide_dialog_title">欢迎使用短信打卡助手 🎉</string>
    <string name="guide_prerequisite_title">【前置条件】</string>
    <string name="guide_step0">⚡ 请先在钉钉「设置 → 考勤打卡 → 极速打卡」中开启极速打卡</string>
    <string name="guide_permission_title">【必须权限】初次使用请确保完成以下授权：</string>
    <string name="guide_step1">1. 短信权限 → 监听打卡短信，否则无法触发</string>
    <string name="guide_step2">2. 通知权限 → 前台服务常驻通知，否则服务会被杀死</string>
    <string name="guide_step3">3. 电池优化白名单 → 防止后台被系统清理</string>
    <string name="guide_step4">4. 悬浮窗权限 → 后台自动打开钉钉（Android 12+ 必需）</string>
    <string name="guide_usage_title">【使用方法】</string>
    <string name="guide_step5">5. 点击⚙或「服务状态」卡片进入设置，配置关键字和白名单</string>
    <string name="guide_step6">6. 打开主界面上的服务开关，开始监听</string>
    <string name="guide_confirm">知道了</string>

